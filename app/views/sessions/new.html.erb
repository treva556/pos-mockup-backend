<% content_for :title, "Log In" %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-heading">
      <span class="eyebrow">Welcome back</span>
      <h1>Log in</h1>

      <p>
        Access your organization and continue managing
        the business.
      </p>
    </div>

    <%= form_with url: login_path,
                  method: :post,
                  class: "app-form" do |form| %>

      <div class="form-group">
        <%= form.label :email %>

        <%= form.email_field :email,
                             required: true,
                             autofocus: true,
                             autocomplete: "email",
                             value: params[:email],
                             placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= form.label :password %>

        <%= form.password_field :password,
                                required: true,
                                autocomplete: "current-password" %>
      </div>

      <%= form.submit "Log in",
                      class: "button button-primary button-full" %>
    <% end %>

    <p class="auth-footer">
      New to the platform?
      <%= link_to "Create an account", sign_up_path %>
    </p>
  </div>
</div>