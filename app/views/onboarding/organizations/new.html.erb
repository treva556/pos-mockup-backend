<% content_for :title, "Create Organization" %>

<div class="setup-page">
  <div class="setup-card">
    <div class="setup-progress">
      <div class="progress-step complete">
        <span>1</span>
        <p>Account</p>
      </div>

      <div class="progress-line"></div>

      <div class="progress-step active">
        <span>2</span>
        <p>Organization</p>
      </div>

      <div class="progress-line"></div>

      <div class="progress-step">
        <span>3</span>
        <p>Dashboard</p>
      </div>
    </div>

    <div class="auth-heading">
      <span class="eyebrow">Company setup</span>
      <h1>Tell us about the organization</h1>

      <p>
        We will automatically create a Main Branch and assign
        you as the organization owner.
      </p>
    </div>

    <%= render "shared/errors", object: @organization %>

    <%= form_with model: @organization,
                  url: onboarding_organization_path,
                  class: "app-form" do |form| %>

      <div class="form-grid">
        <div class="form-group">
          <%= form.label :name, "Trading name" %>

          <%= form.text_field :name,
                              required: true,
                              autofocus: true,
                              placeholder: "e.g. Mwangaza Hardware" %>
        </div>

        <div class="form-group">
          <%= form.label :legal_name,
                         "Registered/legal name" %>

          <%= form.text_field :legal_name,
                              placeholder: "Optional" %>
        </div>

        <div class="form-group">
          <%= form.label :phone %>

          <%= form.telephone_field :phone,
                                   placeholder: "+254..." %>
        </div>

        <div class="form-group">
          <%= form.label :email,
                         "Organization email" %>

          <%= form.email_field :email,
                               placeholder: "accounts@example.com" %>
        </div>

        <div class="form-group">
          <%= form.label :country_code, "Country" %>

          <%= form.select :country_code,
                          [["Kenya", "KE"]],
                          {},
                          required: true %>
        </div>

        <div class="form-group">
          <%= form.label :currency_code, "Currency" %>

          <%= form.select :currency_code,
                          [["Kenyan Shilling (KES)", "KES"]],
                          {},
                          required: true %>
        </div>
      </div>

      <%= form.hidden_field :time_zone,
                            value: "Africa/Nairobi" %>

      <%= form.submit "Create organization",
                      class: "button button-primary" %>
    <% end %>
  </div>
</div>